# Port service agent (local dev only)
PORT=8787

# Public URL — set to deployed URL on Vercel, e.g. https://your-agent.vercel.app
# Falls back to http://localhost:$PORT in dev
AGENT_PUBLIC_URL=

# Delegate key bount-AI menandatangani redelegasi + alamat yang dipakai user saat
# grant budget (GET /spike/agent). Tanpa ini, alamat di-generate ulang tiap
# restart → grant tersimpan di browser jadi tidak cocok. Set 0x + 64 hex.
AGENT_DELEGATE_PRIVATE_KEY=

# Settlement on-chain (gated, default OFF → x402 disimulasi). Set ketiganya
# untuk mengaktifkan percobaan redeem nyata; gagal → fallback ke simulasi.
ENABLE_ONCHAIN_SETTLEMENT=
SETTLEMENT_PRIVATE_KEY=
RPC_URL=

# Venice AI (Fase 3) — https://docs.venice.ai
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
# Image model for /image/generate (e.g. venice-sd35, qwen-image). Key must have image access.
VENICE_IMAGE_MODEL=venice-sd35


# Terminal 3 TEE ADK (bounty challenge)
T3N_API_KEY=
T3N_ENVIRONMENT=testnet

